        "scripts/check_release_policy.py",
        "scripts/check_anonymized_release.py",
        "scripts/check_project_handoff.py"
      ],
      "upstream_agents": [
        "section_writing_agent",
        "venue_compliance_agent",
        "submission_readiness_agent",
        "release_packaging_agent"
      ],
      "downstream_agents": [],
