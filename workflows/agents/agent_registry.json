        "workflows/release/exports/integrated_demo_release_export.zip",
        "workflows/release/deposit/integrated_demo_release_CITATION.cff",
        "workflows/release/deposit/integrated_demo_release_codemeta.json",
        "workflows/release/deposit/integrated_demo_release_zenodo_metadata.json",
        "workflows/release/deposit/integrated_demo_release_osf_metadata.json"
      ],
      "validators": [
        "scripts/check_release_bundle.py",
        "scripts/check_archive_export.py",
        "scripts/check_export_bundle.py",
        "scripts/check_deposit_metadata.py"
      ],
      "upstream_agents": [
        "figure_agent",
        "literature_grounding_agent",
        "review_evidence_agent",
        "section_writing_agent",
        "venue_compliance_agent",
        "submission_readiness_agent"
      ],
      "downstream_agents": [
        "project_handoff_agent",
        "evaluation_agent"
      ],
      "authoritative_outputs": [
        "workflows/release/profiles/profiles.yml",
        "workflows/release/exports/integrated_demo_release_export.tar.gz",
        "workflows/release/exports/integrated_demo_release_export.zip",
        "workflows/release/deposit/integrated_demo_release_CITATION.cff",
        "workflows/release/deposit/integrated_demo_release_codemeta.json",
        "workflows/release/deposit/integrated_demo_release_zenodo_metadata.json",
        "workflows/release/deposit/integrated_demo_release_osf_metadata.json"
      ],
      "public_description": "Packages the validated system state into release, archive, export, and deposit surfaces without renaming the legacy compatibility layer."
    },
    {
